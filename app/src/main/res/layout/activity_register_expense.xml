<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1FA"
    tools:context=".RegisterExpenseActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrar gasto 💸"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#3F2A63"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Monto gastado"
            android:inputType="numberDecimal"
            android:backgroundTint="#7E57C2"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/txtTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp" />

        <EditText
            android:id="@+id/etCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Categoría"
            android:backgroundTint="#7E57C2"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/etAmount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Descripción"
            android:backgroundTint="#7E57C2"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/etCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnSaveExpense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Guardar gasto"
            android:textColor="@android:color/white"
            android:backgroundTint="#7E57C2"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/etDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp" />

        <Button
            android:id="@+id/btnSelectVoucher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Adjuntar váucher 📸"
            android:textColor="@android:color/white"
            android:backgroundTint="#5E35B1"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/btnSaveExpense"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <ImageView
            android:id="@+id/imgVoucher"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:background="#D9D9D9"
            app:layout_constraintTop_toBottomOf="@id/btnSelectVoucher"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnGoExpenses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver gastos"
            android:textColor="@android:color/white"
            android:backgroundTint="#5E35B1"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/imgVoucher"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Volver al inicio"
            android:textColor="@android:color/white"
            android:backgroundTint="#9575CD"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/btnGoExpenses"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>