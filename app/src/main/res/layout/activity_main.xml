<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1FA"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="FinanFácil 💰"
            android:textColor="#312E81"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="Control inteligente de gastos"
            android:textColor="#64748B"
            android:textSize="16sp" />

        <!-- TARJETA RESUMEN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Resumen Financiero"
                android:textColor="#312E81"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotalSpent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="💰 Total gastado: S/ 0.00"
                android:textColor="#4F46E5"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtExpensesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="📝 Gastos registrados: 0"
                android:textColor="#0F766E"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txtLastCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="🏷 Última categoría: -"
                android:textColor="#EA580C"
                android:textSize="18sp" />

        </LinearLayout>

        <!-- BOTONES -->

        <Button
            android:id="@+id/btnRegisterExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4F46E5"
            android:padding="14dp"
            android:text="➕ Registrar gasto"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnViewExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#3730A3"
            android:padding="14dp"
            android:text="📋 Ver gastos"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnStatistics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#0891B2"
            android:padding="14dp"
            android:text="📊 Estadísticas"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#DC2626"
            android:padding="14dp"
            android:text="🚪 Cerrar sesión"
            android:textColor="@android:color/white" />

    </LinearLayout>

</ScrollView>
