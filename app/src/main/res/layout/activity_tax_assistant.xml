<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_blue"
    tools:context=".StatisticsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧾 Asistente Tributario"
            android:textColor="@color/ff_text"
            android:textSize="30sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTaxAssistant"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="🧾\nTributario"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:backgroundTint="#2563EB"
            app:cornerRadius="20dp"/>

        <!-- Tarjeta principal -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_hero_blue"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 Total potencialmente deducible"
                android:textColor="#DDEBFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotalDeducible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="S/ 0.00"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- KPIs -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_glass_card_blue"
                android:elevation="6dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄 Gastos"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtCantidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="@color/ff_primary_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_glass_card_blue"
                android:elevation="6dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:text="💵 Promedio"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtPromedio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="S/0.00"
                    android:textColor="@color/ff_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_glass_card_blue"
                android:elevation="6dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:text="📅 Este mes"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtMes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="S/0.00"
                    android:textColor="@color/ff_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_glass_card_blue"
                android:elevation="6dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:text="🏆 Principal"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtTopCategoria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="-"
                    android:textColor="@color/ff_primary_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Gráfico -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="16dp">

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="330dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="📊 Gastos por mes"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/ff_text"/>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtEmptyStatistics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="24dp"
                android:text="Registra gastos para ver tus estadísticas"
                android:textColor="@color/ff_text_soft"
                android:textSize="17sp"
                android:visibility="gone"/>

        </LinearLayout>

        <TextView
            android:id="@+id/txtTopCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_glass_card_blue"
            android:elevation="6dp"
            android:padding="18dp"
            android:text="Categorías potencialmente deducibles"
            android:textColor="@color/ff_text"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtDetalletributario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_card_blue"
            android:elevation="6dp"
            android:padding="18dp"
            android:text="Ranking de categorías"
            android:textColor="@color/ff_text"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:id="@+id/layoutRanking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"/>

        <LinearLayout
            android:id="@+id/cardInsights"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card_blue"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 Análisis Inteligente"
                android:textColor="@color/ff_text"
                android:textSize="19sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/ff_text"
                android:textSize="16sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card_blue"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 Comparación mensual"
                android:textColor="@color/ff_text"
                android:textSize="19sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtMonthlyComparison"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/ff_text"
                android:textSize="16sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card_blue"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 Gastos deducibles y no deducibles (Anual)"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/ff_text"/>

            <TextView
                android:id="@+id/txtDeductible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="🟢 Deducibles: S/ 0.00"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtNoDeductible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="🔴 No deducibles: S/ 0.00"
                android:textSize="16sp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/txtDeductibleInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card_blue"
            android:padding="18dp"
            android:textColor="@color/ff_text"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/txtRecommendations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_card_blue"
            android:padding="18dp"
            android:textColor="@color/ff_text"
            android:textSize="16sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportPdf"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="📄 Exportar reporte PDF"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:backgroundTint="#2563EB"
            app:cornerRadius="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewDeductibles"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="📄 Ver gastos deducibles"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:backgroundTint="#16A34A"
            app:cornerRadius="18dp"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/btn_primary_gradient"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold"/>

    </LinearLayout>

</ScrollView>