<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinanFacil"
        tools:targetApi="31">

        <!-- Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Registro -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <!-- Pantalla principal -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Registro de gastos -->
        <activity
            android:name=".RegisterExpenseActivity"
            android:exported="false" />

        <!-- Lista de gastos -->
        <activity
            android:name=".ExpensesActivity"
            android:exported="false" />

        <!-- Detalle del gasto -->
        <activity
            android:name=".ExpenseDetailActivity"
            android:exported="false" />

        <!-- Estadísticas -->
        <activity
            android:name=".StatisticsActivity"
            android:exported="false" />

        <!-- Asistente Tributario -->
        <activity
            android:name=".TaxAssistantActivity"
            android:exported="false" />

        <!-- Gastos potencialmente deducibles -->
        <activity
            android:name=".DeductibleExpensesActivity"
            android:exported="false" />

    </application>

</manifest>